# Telegram: @BotFather -> token. Group Privacy should be OFF to log all messages.
BOT_TOKEN=

# Z.AI OpenAI-compatible API (same key as in Roo Code if you use paas endpoint)
Z_AI_API_KEY=
# Optional override; default is https://api.z.ai/api/paas/v4
# Z_AI_BASE_URL=https://api.z.ai/api/paas/v4/

# Model id for chat completions
DIGEST_MODEL=glm-5.1

# IANA timezone for calendar-day boundaries
DIGEST_TZ=Europe/Moscow

# Bump to invalidate cached digests without changing prompts in code
PROMPT_VERSION=1

# SQLite path (relative to cwd or absolute)
DATABASE_PATH=data/bot.sqlite3

# Comma-separated numeric Telegram user ids allowed to run /digest (not @username).
# Example: DIGEST_ALLOWED_USER_IDS=123456789,987654321
# Legacy env name ADMIN_USER_IDS is still read if DIGEST_ALLOWED_USER_IDS is empty.
DIGEST_ALLOWED_USER_IDS=

# Max messages included per day (oldest dropped first after sort); 0 = unlimited
DIGEST_MAX_MESSAGES=3000

# Approx max characters per LLM chunk before map-reduce summarization
DIGEST_CHUNK_CHARS=32000

# Optional: log level DEBUG to see cache hits and token usage
# LOG_LEVEL=INFO
